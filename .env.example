# Copy to .env for local development. If unset, the agent falls back to your
# Application Default Credentials project. The Gemini location is pinned to
# "global" in code (that is where gemini-flash-latest is served), so it is not
# configured here.

# GCP project that hosts the agent and serves Gemini via Vertex AI.
GOOGLE_CLOUD_PROJECT=your-project-id

# Route model calls through Vertex AI (not the public Gemini API).
GOOGLE_GENAI_USE_VERTEXAI=True
